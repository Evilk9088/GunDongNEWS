<Window x:Class="桌面新闻.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面新闻 - 配置中心" Height="450" Width="600" 
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <!-- 上面占满剩余空间，放选项卡 -->
            <RowDefinition Height="*"/>
            <!-- 下面固定高度，放保存按钮 -->
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 选项卡控件 -->
        <TabControl Grid.Row="0" Margin="10">

            <!-- 第一页：基础设置 -->
            <TabItem Header="基础设置">
                <StackPanel Margin="20">
                    <!-- 原有控件保持不变 -->
                    <CheckBox x:Name="ChkIsVisible" Content="开启桌面新闻滚动条" FontWeight="Bold" Margin="0,10"/>
                    <CheckBox x:Name="ChkStartMinimized" Content="开机启动时隐藏配置窗口 (仅显示托盘)" Margin="0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,15">
                        <TextBlock Text="当前运行模式：" VerticalAlignment="Center" Width="100"/>
                        <ComboBox x:Name="CmbMode" Width="150" VerticalAlignment="Center">
                            <ComboBoxItem Content="网络新闻模式" Tag="News"/>
                            <ComboBoxItem Content="本地小说模式" Tag="LocalText"/>
                        </ComboBox>
                        
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15">
                        <TextBlock Text="本地小说路径：" VerticalAlignment="Center" Width="100"/>
                        <TextBox x:Name="TxtNovelPath" Width="300" VerticalAlignment="Center" IsReadOnly="True"/>
                        <Button Content="浏览..." Width="60" Margin="5,0,0,0" Click="BtnBrowseFile_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <TextBlock Text="新闻刷新间隔：" VerticalAlignment="Center" Width="100"/>
                        <TextBox x:Name="TxtInterval" Width="50" VerticalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text=" 分钟" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- ===== 新增：外观与位置设置 ===== -->
                    <Separator Margin="0,20"/>
                    <TextBlock Text="外观与位置" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <!-- 滚动速度 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="滚动速度：" VerticalAlignment="Center" Width="100"/>
                        <Slider x:Name="SliderSpeed" Minimum="20" Maximum="300" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <TextBlock Text="{Binding ElementName=SliderSpeed, Path=Value, StringFormat={}{0:F0}}" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 字体大小 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="字体大小：" VerticalAlignment="Center" Width="100"/>
                        <Slider x:Name="SliderFontSize" Minimum="12" Maximum="28" IsSnapToTickEnabled="True" TickFrequency="1" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=SliderFontSize, Path=Value, StringFormat={}{0:F0}px}" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 位置调整 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="位置(Top,Left):" VerticalAlignment="Center" Width="100"/>
                        <TextBox x:Name="TxtTop" Width="60" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtLeft" Width="60"/>
                        <CheckBox x:Name="ChkPositionLocked" Content="锁定位置" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>

                </StackPanel>
            </TabItem>

            <!-- 第二页：新闻源(API)管理 -->
            <TabItem Header="数据源管理">
                <Grid Margin="5">
                    <!-- DataGrid 可以像 Excel 一样直接在表格里修改数据 -->
                    <DataGrid x:Name="ApiDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#FFF0F0F0">
                        <DataGrid.Columns>
                            <!-- 绑定了对象的 IsEnabled 属性，表现为勾选框 -->
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                            <!-- 绑定了 Name 属性 -->
                            <DataGridTextColumn Header="数据源名称" Binding="{Binding Name}" Width="100" IsReadOnly="True"/>
                            <!-- 绑定了 ShowCount 属性 -->
                            <DataGridTextColumn Header="显示条数" Binding="{Binding ShowCount}" Width="80"/>
                            <!-- 绑定了 Url 属性 -->
                            <DataGridTextColumn Header="接口地址 (URL)" Binding="{Binding Url}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 第三页：黑名单管理 -->
            <TabItem Header="过滤黑名单">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="屏蔽包含以下词汇的新闻 (一行一个词)：" Foreground="Gray" Margin="0,0,0,5"/>
                    <!-- AcceptsReturn="True" 允许在文本框里按回车换行 -->
                    <TextBox x:Name="TxtBlacklist" Grid.Row="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Padding="5"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- 底部保存区域 -->
        <Border Grid.Row="1" Background="#FFF5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Button Content="💾 保存并应用全部设置" Width="200" Height="35" Background="#FF1E90FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click"/>
        </Border>
    </Grid>
</Window>